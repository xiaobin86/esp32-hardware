      "text": "📋 关键代码证据 (Evidence)\n\n// ===== 字库读取：手动控制 CS =====\nbool fontRead(uint32_t addr) {\n  digitalWrite(TFT_CS, HIGH);                    // ⬆️ 确保屏幕未选中\n  SPI.beginTransaction(SPISettings(8MHz, MSBFIRST, SPI_MODE0));\n  digitalWrite(FONT_CS, LOW);                     // ⬇️ 选中字库\n  SPI.transfer(0x03); SPI.transfer(addr>>16); SPI.transfer(addr>>8); SPI.transfer(addr);\n  for (int i=0; i<32; i++) fontBuf[i] = SPI.transfer(0x00);  // 读取字模\n  digitalWrite(FONT_CS, HIGH);                    // ⬆️ 释放字库\n  SPI.endTransaction();\n}\n\n// ===== 屏幕显示：库自动管理 CS (Adafruit_SPITFT.cpp) =====\nvoid Adafruit_SPITFT::drawRGBBitmap(int16_t x, int16_t y, uint16_t *bitmap, int16_t w, int16_t h) {\n  startWrite();           // ← 内部调用 csLow()  ⬇️ 自动拉低 TFT_CS\n  setAddrWindow(x, y, w, h);\n  // ... 通过 SPI 写入像素数据 ...\n  endWrite();             // ← 内部调用 csHigh() ⬆️ 自动拉高 TFT_CS\n}",
      "originalText": "📋 关键代码证据 (Evidence)\n\n// ===== 字库读取：手动控制 CS =====\nbool fontRead(uint32_t addr) {\n  digitalWrite(TFT_CS, HIGH);                    // ⬆️ 确保屏幕未选中\n  SPI.beginTransaction(SPISettings(8MHz, MSBFIRST, SPI_MODE0));\n  digitalWrite(FONT_CS, LOW);                     // ⬇️ 选中字库\n  SPI.transfer(0x03); SPI.transfer(addr>>16); SPI.transfer(addr>>8); SPI.transfer(addr);\n  for (int i=0; i<32; i++) fontBuf[i] = SPI.transfer(0x00);  // 读取字模\n  digitalWrite(FONT_CS, HIGH);                    // ⬆️ 释放字库\n  SPI.endTransaction();\n}\n\n// ===== 屏幕显示：库自动管理 CS (Adafruit_SPITFT.cpp) =====\nvoid Adafruit_SPITFT::drawRGBBitmap(int16_t x, int16_t y, uint16_t *bitmap, int16_t w, int16_t h) {\n  startWrite();           // ← 内部调用 csLow()  ⬇️ 自动拉低 TFT_CS\n  setAddrWindow(x, y, w, h);\n  // ... 通过 SPI 写入像素数据 ...\n  endWrite();             // ← 内部调用 csHigh() ⬆️ 自动拉高 TFT_CS\n}",
      "fontSize": 13,
