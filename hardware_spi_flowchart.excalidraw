    {
      "type": "text",
      "id": "decode_text",
      "x": 60,
      "y": 650,
      "width": 480,
      "height": 60,
      "text": "for(row=0; row<16; row++) {\n  b0 = fontBuf[row*2];  b1 = fontBuf[row*2+1];\n  for(col=0; col<8; col++) {\n    pixBuf[row*16+col] = (b0 & (0x80>>col)) ? fg : bg;\n    pixBuf[row*16+8+col] = (b1 & (0x80>>col)) ? fg : bg;\n  }\n}",
      "originalText": "for(row=0; row<16; row++) {\n  b0 = fontBuf[row*2];  b1 = fontBuf[row*2+1];\n  for(col=0; col<8; col++) {\n    pixBuf[row*16+col] = (b0 & (0x80>>col)) ? fg : bg;\n    pixBuf[row*16+8+col] = (b1 & (0x80>>col)) ? fg : bg;\n  }\n}",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 100075,
      "version": 1,
      "versionNonce": 100076,
      "isDeleted": false,
      "groupIds": [],
